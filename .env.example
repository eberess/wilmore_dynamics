# Configuration SMTP (obligatoire pour le formulaire de contact)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=contact@example.com
SMTP_PASS=your-secure-password-here
SMTP_FROM=contact@example.com
CONTACT_EMAIL=contact@example.com
SMTP_TLS=true
SMTP_SECURE=true

# Configuration de l'application
NODE_APP_PORT=3000
NODE_ENV=production

# Configuration Redis (obligatoire pour rate limiting et CSRF)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password

# Analytics Umami (optionnel)
# UMAMI_WEBSITE_ID=your-website-id-here
# UMAMI_SCRIPT_URL=https://your-umami-domain.com/script.js